    "embed-worker.js",
    "lib.js",
    "server-deps.json",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/BrainSlugs83/GithubCopilotCLI-VectorMemoryMCP#installation",
  "repository": {
