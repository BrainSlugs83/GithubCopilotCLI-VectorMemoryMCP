    "url": "https://github.com/BrainSlugs83/GithubCopilotCLI-VectorMemoryMCP.git"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "github-copilot",
    "github-copilot-cli",
    "copilot-cli",
    "vector-search",
